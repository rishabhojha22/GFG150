class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int lar1=Integer.MIN_VALUE;
        int lar2=Integer.MIN_VALUE;
        
        int len=arr.length;
        
        for(int i=0;i<len;i++){
            if(arr[i]>lar1){
                lar2=lar1;
                lar1=arr[i];
            }
            if(arr[i]<lar1 && arr[i]>lar2){
                lar2=arr[i];
            }
        }
        
        return (lar2==Integer.MIN_VALUE)? -1 : lar2;
    }
