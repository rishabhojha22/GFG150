class Solution {
    public char nonRepeatingChar(String s) {
        // code here
        int arr[]=new int[26];
        int n=s.length();
        
        for(int i=0;i<n;i++){
            int idx=s.charAt(i)-'a';
            arr[idx]++;
        }
        
        for(int i=0;i<n;i++){
            int idx=s.charAt(i)-'a';
            if(arr[idx]==1)return s.charAt(i);
        }
        
        return '$';
    }
}
